# Copy to .env.local and fill in. .env.local is gitignored.

# Mapbox access token (exposed to the browser — must be a publishable pk.* token).
# Local dev needs a token allowlisted for localhost; production needs one
# allowlisted for the deploy domain.
VITE_MAPBOX_TOKEN=

# --- Notion (Phase 2+, server-side only — never prefixed VITE_) ---
# NOTION_TOKEN=
# NOTION_DATABASE_ID=
