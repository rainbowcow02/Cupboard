# Copy to .env.local and fill in. .env.local is gitignored.

# Mapbox access token (exposed to the browser — must be a publishable pk.* token).
# Local dev needs a token allowlisted for localhost; production needs one
# allowlisted for the deploy domain.
VITE_MAPBOX_TOKEN=

# Notion — server-side only (no VITE_ prefix, so never shipped to the browser).
# Read by the /api functions. Used by `vercel dev` and by Vercel in production.
#   NOTION_TOKEN        — internal integration secret from notion.so/my-integrations
#   NOTION_DATABASE_ID  — the 32-char id in your Notion table's URL
NOTION_TOKEN=
NOTION_DATABASE_ID=
